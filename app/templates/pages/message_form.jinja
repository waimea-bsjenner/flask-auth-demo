{#=====================================================
  Help page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <h2>New Message</h2>

    <form method="post" action="/message">

      <label>
        Title
          <input type="text" name="title">
      </label>

      <label>
        Body
          <input type="text" name="body" required>
      </label>

      <button>Submit</button>
    </form>

{% endblock %}

